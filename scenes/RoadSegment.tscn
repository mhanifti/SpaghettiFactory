[sub_resource type="GDScript" id="GDScript_tbgi4"]
script/source = "extends Path2D

## For Make a Road
@onready var line_2d = $Line2D

var next_road: Array[Path2D] = []
var prev_road: Array[Path2D] = []

func update_view():
	# Mengambil titik-titik dari curve untuk ditampilkan di Line2D
	line_2d.points = curve.get_baked_points()

func set_straight(start: Vector2, end: Vector2):
	curve.clear_points()
	curve.add_point(start)
	curve.add_point(end)
	update_view()
	
func set_curv(start: Vector2, mid: Vector2, end: Vector2):
	curve.clear_points()
	curve.add_point(start)
	if end:
		curve.add_point(end, mid - end, Vector2.ZERO)
	else:	
		curve.add_point(mid)
	update_view()

## For Car Moving
@export var car_scene: PackedScene # Drag Car.tscn ke sini
@export var path_follow_scene: PackedScene

func spawn_car(direction_start: bool) -> PathFollow2D:
	# 1. Buat Follower baru (agar independen)
	var new_follower = path_follow_scene.instantiate()
	new_follower.loop = false # Matikan agar tidak balik ke awal otomatis
	new_follower.rotates = true # Mobil menghadap ke arah jalan
	
	# 2. Masukkan ke RoadSegment
	self.add_child(new_follower)
	
	# 3. Masukkan Mobil ke dalam Follower
	var car = car_scene.instantiate()
	new_follower.add_child(car)
	
	# 4. Atur posisi awal & arah
	if direction_start:
		new_follower.progress_ratio = 0
	else:
		new_follower.progress_ratio = 1.0
	
	# Pasang script pergerakan ke follower secara dinamis atau lewat class
	new_follower.set_script(load(\"res://scenes/path_follow_car.gd\"))
	
	return new_follower
"

[sub_resource type="GDScript" id="GDScript_tefeu"]
script/source = "extends PathFollow2D

@export var speed: float = 200.0

var current_storage: int = 0
var max_capacity: int = 10

func _process(delta: float) -> void:
	# Hitung pergerakan berdasarkan arah
	var car = get_child(0)
	var label = car.get_child(1)
	
	if label:
		label.text = str(current_storage) + \" / \" + str(max_capacity)
	var movement = speed * delta
	
	var is_from_start = self.get_meta(\"moving_forward\", true)
	
	if is_from_start:
		progress += movement
	else:
		progress -= movement

func _on_child_entered_tree(node: Node) -> void:
	# Cek apakah yang masuk memiliki sprite (Mobil)
	if node.find_child(\"*Sprite2D*\"):
		print(\"Mobil masuk ke jalur!\")	

func _on_child_exiting_tree(node: Node) -> void:
	print(\"Mobil keluar dari jalur!\")

func add_cargo(amount: int):
	current_storage = clamp(current_storage + amount, 0, max_capacity)

func remove_cargo(amount: int):
	current_storage = clamp(current_storage - amount, 0, max_capacity)
"

